<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice Audit Report - {{ invoice_no }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      background: #f5f5f5;
      padding: 2rem;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    header {
      background: #1a365d;
      color: #fff;
      padding: 1.5rem 2rem;
    }
    header h1 { font-size: 1.5rem; font-weight: 600; }
    header p { font-size: 0.9rem; opacity: 0.85; margin-top: 0.25rem; }
    section {
      padding: 1.5rem 2rem;
      border-bottom: 1px solid #e2e8f0;
    }
    section:last-child { border-bottom: none; }
    h2 {
      font-size: 1.15rem;
      color: #1a365d;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #e2e8f0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 0.5rem;
    }
    th, td {
      padding: 0.6rem 0.8rem;
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
    }
    th {
      background: #f7fafc;
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      color: #4a5568;
    }
    td { font-size: 0.9rem; }
    .badge {
      display: inline-block;
      padding: 0.3rem 0.8rem;
      border-radius: 4px;
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
    }
    .badge-auto_approve { background: #c6f6d5; color: #22543d; }
    .badge-flag { background: #fefcbf; color: #744210; }
    .badge-manual_review { background: #feebc8; color: #7b341e; }
    .badge-reject { background: #fed7d7; color: #822727; }
    .badge-pass { background: #c6f6d5; color: #22543d; }
    .badge-unknown { background: #e2e8f0; color: #4a5568; }
    .success-text { color: #2f855a; font-weight: 500; }
    .warning-text { color: #c05621; font-weight: 500; }
    ol.audit-list {
      list-style: decimal;
      padding-left: 1.5rem;
    }
    ol.audit-list li {
      padding: 0.3rem 0;
      font-size: 0.9rem;
      color: #4a5568;
    }
    .reviewer-note {
      margin-top: 0.75rem;
      padding: 0.5rem 0.75rem;
      background: #ebf8ff;
      border-left: 3px solid #3182ce;
      font-size: 0.9rem;
      color: #2b6cb0;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Invoice Audit Report</h1>
      <p>Invoice: {{ invoice_no }} | Status: {{ status | upper }}</p>
    </header>

    <!-- Section 1: Invoice Summary -->
    <section id="invoice-summary">
      <h2>Invoice Summary</h2>
      <table>
        <tbody>
          <tr><th>Invoice No.</th><td>{{ extracted.get("invoice_no", "N/A") }}</td></tr>
          <tr><th>Vendor Name</th><td>{{ extracted.get("vendor_name", "N/A") }}</td></tr>
          <tr><th>Vendor ID</th><td>{{ extracted.get("vendor_id", "N/A") }}</td></tr>
          <tr><th>Invoice Date</th><td>{{ extracted.get("invoice_date", "N/A") }}</td></tr>
          <tr><th>PO Number</th><td>{{ extracted.get("po_number", "N/A") }}</td></tr>
          <tr><th>Currency</th><td>{{ extracted.get("currency", "N/A") }}</td></tr>
          <tr><th>Total Amount</th><td>{{ extracted.get("total_amount", "N/A") }}</td></tr>
        </tbody>
      </table>
    </section>

    <!-- Section 2: Translation Details -->
    <section id="translation-details">
      <h2>Translation Details</h2>
      {% if translated.get("is_english", true) %}
        <p class="success-text">No translation needed &mdash; source document is in English.</p>
      {% else %}
        <table>
          <tbody>
            <tr><th>Source Language</th><td>{{ translated.get("source_language", "N/A") }}</td></tr>
            <tr><th>Translation Confidence</th><td>{{ translated.get("translation_confidence", "N/A") }}</td></tr>
          </tbody>
        </table>
      {% endif %}
    </section>

    <!-- Section 3: Data Completeness Table -->
    <section id="data-completeness">
      <h2>Data Completeness</h2>
      {% set missing = validation_result.get("missing_fields", []) %}
      {% set all_missing = validation_result.get("all_missing", []) %}
      {% if missing or all_missing %}
        <table>
          <thead>
            <tr>
              <th>Missing Field</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            {% for field in all_missing %}
            <tr>
              <td>{{ field }}</td>
              <td>
                {% if field in missing %}
                  <span class="badge badge-{{ validation_result.get('status', 'flag') }}">{{ validation_result.get("status", "flag") }}</span>
                {% else %}
                  <span class="badge badge-flag">flag</span>
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="success-text">All required fields present.</p>
      {% endif %}
    </section>

    <!-- Section 4: Business Validation Diff -->
    <section id="business-validation">
      <h2>Business Validation</h2>
      {% set discrepancies = validation_result.get("discrepancies", []) %}
      {% if discrepancies %}
        <table>
          <thead>
            <tr>
              <th>Item Code</th>
              <th>Field</th>
              <th>Invoice Value</th>
              <th>ERP Value</th>
              <th>Deviation %</th>
            </tr>
          </thead>
          <tbody>
            {% for d in discrepancies %}
            <tr>
              <td>{{ d.get("item_code", "") }}</td>
              <td>{{ d.get("field", "") }}</td>
              <td>{{ d.get("invoice_value", "") }}</td>
              <td>{{ d.get("erp_value", "") }}</td>
              <td>{{ d.get("deviation_pct", "") }}%</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="success-text">No discrepancies found.</p>
      {% endif %}
    </section>

    <!-- Section 5: Recommendation Badge -->
    <section id="recommendation">
      <h2>Recommendation</h2>
      <p>
        <span class="badge badge-{{ status }}">{{ status }}</span>
      </p>
      {% if validation_result.get("reviewer_decision") %}
        <div class="reviewer-note">
          Reviewer decision: <strong>{{ validation_result.get("reviewer_decision") }}</strong>
        </div>
      {% endif %}
    </section>

    <!-- Section 6: Audit Trail -->
    <section id="audit-trail">
      <h2>Audit Trail</h2>
      {% if messages %}
        <ol class="audit-list">
          {% for msg in messages %}
            <li>{{ msg }}</li>
          {% endfor %}
        </ol>
      {% else %}
        <p>No audit trail entries.</p>
      {% endif %}
    </section>
  </div>
</body>
</html>
